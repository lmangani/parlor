# Path to a local Gemma 4 E2B model (optional — auto-downloads from HuggingFace if not set)
# MODEL_PATH=/path/to/gemma-4-E2B-it.litertlm

# Server port (default: 8000)
# PORT=8000

# Optional agent tools: comma-separated names, or "none" (respond_to_user is always on)
# Default: web_search,read_web_page,get_current_utc_time
# PARLOR_TOOLS=web_search,read_web_page,get_current_utc_time
# PARLOR_HTTP_TIMEOUT=12
# PARLOR_MAX_SEARCH_QUERY_LEN=240
# PARLOR_MAX_WEB_SEARCH_CHARS=4000
# Max chars returned to the model from read_web_page (plain text / HTML stripped)
# PARLOR_MAX_READ_PAGE_CHARS=10000
# PARLOR_MAX_PAGE_URL_LEN=2048
# Max chars of last web_search result re-injected each user turn (follow-up memory)
# PARLOR_SEARCH_MEMORY_CHARS=9000
